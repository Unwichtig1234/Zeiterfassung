{
  "name": "zeiterfassung-pro-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Zeiterfassung, Projektplanung, Gantt und Ressourcenboard als Desktop-App",
  "main": "electron/main.cjs",
  "author": "OpenAI",
  "scripts": {
    "dev": "vite",
    "electron:dev": "ELECTRON_START_URL=http://localhost:5173 electron .",
    "build:web": "vite build",
    "dist": "npm run build:web && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "jspdf": "^2.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "de.helbig.zeiterfassungpro",
    "productName": "Zeiterfassung Pro",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
